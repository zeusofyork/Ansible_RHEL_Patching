<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Patch Report – {{ inventory_hostname }}</title>
  <style>
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #0f1117; color: #e2e8f0; margin: 0; padding: 24px; }
    h1 { color: #63b3ed; border-bottom: 2px solid #2d3748; padding-bottom: 12px; }
    h2 { color: #90cdf4; font-size: 1em; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 28px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; margin-bottom: 24px; }
    .card { background: #1a1f2e; border: 1px solid #2d3748; border-radius: 8px; padding: 16px; }
    .label { color: #718096; font-size: 0.78em; text-transform: uppercase; letter-spacing: 0.08em; }
    .value { font-size: 1.1em; font-weight: 600; margin-top: 4px; }
    .badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 0.8em; font-weight: 700; }
    .success { background: #1c3a27; color: #68d391; border: 1px solid #276749; }
    .warning { background: #3d2a00; color: #f6ad55; border: 1px solid #744210; }
    .danger  { background: #3d0f0f; color: #fc8181; border: 1px solid #742a2a; }
    .info    { background: #1a2a4a; color: #63b3ed; border: 1px solid #2a4a8a; }
    table { width: 100%; border-collapse: collapse; font-size: 0.88em; }
    th { background: #2d3748; color: #90cdf4; text-align: left; padding: 8px 12px; }
    td { padding: 7px 12px; border-bottom: 1px solid #2d3748; font-family: monospace; }
    tr:hover td { background: #1a1f2e; }
    .section { background: #141824; border: 1px solid #2d3748; border-radius: 8px; padding: 20px; margin-bottom: 20px; }
    footer { color: #4a5568; font-size: 0.78em; margin-top: 32px; }
  </style>
</head>
<body>

<h1>🛡 Patch Report</h1>

<div class="grid">
  <div class="card">
    <div class="label">Hostname</div>
    <div class="value">{{ inventory_hostname }}</div>
  </div>
  <div class="card">
    <div class="label">Operating System</div>
    <div class="value">{{ ansible_distribution }} {{ ansible_distribution_version }}</div>
  </div>
  <div class="card">
    <div class="label">IP Address</div>
    <div class="value">{{ ansible_default_ipv4.address | default('N/A') }}</div>
  </div>
  <div class="card">
    <div class="label">Patch Window</div>
    <div class="value">{{ patch_window }}</div>
  </div>
  <div class="card">
    <div class="label">Status</div>
    <div class="value">
      {% if patch_post_check_failed | default(false) %}
        <span class="badge danger">FAILED</span>
      {% else %}
        <span class="badge success">SUCCESS</span>
      {% endif %}
    </div>
  </div>
  <div class="card">
    <div class="label">Reboot Required</div>
    <div class="value">
      {% if patch_post_facts.reboot_required | default(false) %}
        <span class="badge warning">YES</span>
      {% else %}
        <span class="badge success">NO</span>
      {% endif %}
    </div>
  </div>
</div>

<div class="section">
  <h2>Pre / Post Comparison</h2>
  <table>
    <thead><tr><th>Check</th><th>Before</th><th>After</th></tr></thead>
    <tbody>
      <tr><td>Kernel</td><td>{{ patch_pre_facts.kernel | default('N/A') }}</td><td>{{ patch_post_facts.kernel | default('N/A') }}</td></tr>
      <tr><td>Package Count</td><td>{{ patch_pre_facts.packages | default([]) | length }}</td><td>{{ patch_post_facts.packages | default([]) | length }}</td></tr>
      <tr><td>DNF Transaction ID</td><td>{{ patch_pre_facts.dnf_txid | default('N/A') }}</td><td>{{ patch_post_facts.dnf_txid | default('N/A') }}</td></tr>
      <tr><td>Disk Free (MB)</td><td>{{ patch_pre_facts.disk_free_mb | default('N/A') }}</td><td>—</td></tr>
      <tr><td>Load Average</td><td>{{ patch_pre_facts.load_avg | default('N/A') }}</td><td>—</td></tr>
    </tbody>
  </table>
</div>

{% if patch_post_facts.packages_added | default([]) | length > 0 %}
<div class="section">
  <h2>Packages Updated ({{ patch_post_facts.packages_added | length }})</h2>
  <table>
    <thead><tr><th>Package</th></tr></thead>
    <tbody>
      {% for pkg in patch_post_facts.packages_added | sort %}
      <tr><td>{{ pkg }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}

{% if patch_post_facts.packages_removed | default([]) | length > 0 %}
<div class="section">
  <h2>Packages Removed ({{ patch_post_facts.packages_removed | length }})</h2>
  <table>
    <thead><tr><th>Package</th></tr></thead>
    <tbody>
      {% for pkg in patch_post_facts.packages_removed | sort %}
      <tr><td>{{ pkg }}</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}

<footer>
  Generated by Ansible patching automation · {{ ansible_date_time.iso8601 }} · {{ inventory_hostname }}
</footer>

</body>
</html>
